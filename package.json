{
  "name": "fere",
  "version": "0.1.0",
  "description": "Visualize your local development environment in real-time",
  "author": "Rahul Thennarasu",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "homepage": "./",
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "pg": "^8.18.0",
    "posthog-js": "^1.351.4",
    "posthog-node": "^5.24.17",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-flow": "^1.0.3",
    "react-markdown": "^9.1.0",
    "react-scripts": "5.0.1",
    "react-window": "^2.2.7",
    "reactflow": "^11.11.4",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "wait-on": "^9.0.3"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:no-deprecation": "node --no-deprecation node_modules/react-scripts/scripts/start.js",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "electron": "env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:dev": "concurrently \"BROWSER=none PORT=3001 npm run start:no-deprecation\" \"wait-on http://localhost:3001 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "electron:build": "npm run build && electron-builder",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "test:node": "node --test electron/services/*.test.js electron/security.test.js"
  },
  "build": {
    "appId": "com.fere.app",
    "productName": "Fere",
    "icon": "assets/icon.icns",
    "extends": null,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "dmg": {
      "artifactName": "fere.dmg",
      "title": "Fere ${version}",
      "backgroundColor": "#ffffff",
      "window": {
        "width": 560,
        "height": 360
      },
      "iconSize": 96,
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "name": "Applications",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "assets"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "overrides": {
    "@types/d3-dispatch": "3.0.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
