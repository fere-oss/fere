{
  "name": "fere",
  "version": "2.0.0",
  "description": "Visualize your local development environment in real-time",
  "author": "Rahul Thennarasu",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "bin": {
    "fere-mcp": "./bin/fere-mcp.js"
  },
  "homepage": "./",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@sentry/electron": "^7.10.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.18.126",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "electron-updater": "^6.8.3",
    "openai": "^6.33.0",
    "pg": "^8.18.0",
    "posthog-js": "^1.351.4",
    "posthog-node": "^5.24.17",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-markdown": "^9.1.0",
    "react-scripts": "5.0.1",
    "react-window": "^2.2.7",
    "reactflow": "^11.11.4",
    "rehype-highlight": "^7.0.2",
    "esbuild": "^0.28.0",
    "typescript": "^4.9.5",
    "web-vitals": "^2.1.4"
  },
  "devDependencies": {
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "wait-on": "^9.0.3"
  },
  "scripts": {
    "start": "node scripts/start-react.js",
    "start:no-deprecation": "node --no-deprecation scripts/start-react.js",
    "build": "react-scripts build",
    "typecheck": "tsc --noEmit",
    "test": "react-scripts test",
    "test:coverage": "react-scripts test --coverage --watchAll=false --passWithNoTests",
    "eject": "react-scripts eject",
    "format": "prettier --write \"src/**/*.{ts,tsx,js}\" \"electron/**/*.js\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js}\" \"electron/**/*.js\"",
    "lint": "eslint src --ext .ts,.tsx --max-warnings 0",
    "electron": "env -u ELECTRON_RUN_AS_NODE electron .",
    "electron:dev": "concurrently \"BROWSER=none PORT=3001 npm run start:no-deprecation\" \"wait-on http://localhost:3001 && env -u ELECTRON_RUN_AS_NODE electron .\"",
    "electron:dev:win": "concurrently \"set BROWSER=none&& set PORT=3001&& npm run start:no-deprecation\" \"wait-on http://localhost:3001 && set ELECTRON_RUN_AS_NODE=&& electron .\"",
    "electron:build": "npm run build && npm run build:mcpb && electron-builder",
    "electron:build:mac": "npm run build && npm run build:mcpb && electron-builder --mac",
    "electron:build:win": "npm run build && npm run build:mcpb && electron-builder --win",
    "test:node": "node --test $(find electron/services -type f -name '*.test.js') electron/security.test.js",
    "build:mcpb": "node scripts/build-mcpb.js",
    "release:check": "npm run typecheck && npm run test:node && npm run build",
    "prepare": "husky"
  },
  "build": {
    "appId": "com.fere.app",
    "productName": "Fere",
    "icon": "assets/fere.png",
    "extends": null,
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "mac": {
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "notarize": true,
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "assets/fere.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "artifactName": "fere-setup.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fere"
    },
    "portable": {
      "artifactName": "fere-portable.exe"
    },
    "dmg": {
      "artifactName": "fere.dmg",
      "title": "Fere ${version}",
      "backgroundColor": "#ffffff",
      "window": {
        "width": 560,
        "height": 360
      },
      "iconSize": 96,
      "contents": [
        {
          "x": 150,
          "y": 180,
          "type": "file"
        },
        {
          "x": 410,
          "y": 180,
          "type": "link",
          "name": "Applications",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "build/**/*",
      "electron/**/*",
      "bin/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "bin/**/*",
      "node_modules/@modelcontextprotocol/**/*"
    ],
    "extraResources": [
      {
        "from": "dist/fere.mcpb",
        "to": "fere.mcpb"
      }
    ],
    "directories": {
      "buildResources": "assets"
    },
    "publish": {
      "provider": "github",
      "owner": "RahulThennarasu",
      "repo": "fere-macOS"
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write"
    ],
    "electron/**/*.js": [
      "prettier --write"
    ]
  },
  "jest": {
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/index.tsx"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 60
      }
    }
  },
  "overrides": {
    "@types/d3-dispatch": "3.0.6"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
