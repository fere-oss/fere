# ─── Analytics ────────────────────────────────────────────────────────────────
# Leave blank to disable analytics entirely (safe for local development).
POSTHOG_API_KEY=
REACT_APP_POSTHOG_API_KEY=

# ─── Auth / Cloud (optional) ──────────────────────────────────────────────────
# Required only for the paid-tier auth flow and Sentinel usage limits.
# Copy electron/runtime-config.example.json → electron/runtime-config.json
# instead of setting these here; the main process reads runtime-config.json.
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ─── AI (dev / testing only) ──────────────────────────────────────────────────
# Never shipped in production builds. Used when running Sentinel locally without
# a user-provided key.
OPENAI_API_KEY=

# ─── UI enhancements (optional) ───────────────────────────────────────────────
# Brand logo icons shown next to external API providers in the service graph.
REACT_APP_LOGO_DEV_TOKEN=

# ─── Error reporting (optional) ───────────────────────────────────────────────
REACT_APP_SENTRY_DSN=

# ─── Feature flags ────────────────────────────────────────────────────────────
# Enable Team / Org tier features. Requires a matching cloud backend.
FERE_TEAM_MODE=false
FERE_ORG_MODE=false
