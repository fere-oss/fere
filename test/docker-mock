#!/usr/bin/env node
/**
 * Mock Docker daemon for Fere Dashboard Testing.
 * Listens on a Docker-like port to show the "container" service type.
 */

const http = require('http');

const PORT = parseInt(process.env.PORT || '2375', 10);

const server = http.createServer((_req, res) => {
  res.writeHead(200, { 'Content-Type': 'application/json' });
  res.end(JSON.stringify({ status: 'ok', mock: 'docker' }));
});

server.listen(PORT, '0.0.0.0', () => {
  console.log(`Docker mock listening on port ${PORT}`);
});

process.on('SIGINT', () => {
  server.close(() => process.exit(0));
});
